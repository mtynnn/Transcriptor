{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-appv-transcriptor",
  "version": "0.1.3",
  "identifier": "v-transcriptor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vTranscriptor",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "vtranscriptor-engine"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBMTY4RjdENUNCODVERTQKUldUa1hiaGNmWThXT3VUN2pxOHdsWEkzaU9tQzVnQ1N3Z0FnVndkWEwzQjdyM2lzYlVaaXpzSXUK",
      "endpoints": [
        "https://github.com/mtynnn/Transcriptor/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
